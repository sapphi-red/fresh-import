{
  "name": "fresh-import",
  "version": "0.0.1",
  "description": "Import an ESM entry in its own fresh module graph (separate from Node's module cache) and get back the statically-imported relative dependency files.",
  "homepage": "https://github.com/sapphi-red/fresh-import#readme",
  "bugs": {
    "url": "https://github.com/sapphi-red/fresh-import/issues"
  },
  "license": "MIT",
  "author": "sapphi-red (https://github.com/sapphi-red)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sapphi-red/fresh-import.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/sapphi-red"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "format": "oxfmt"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "rolldown": "^1.0.3",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.34.1"
}
